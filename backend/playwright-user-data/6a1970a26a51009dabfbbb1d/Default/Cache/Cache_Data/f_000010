async function showPage(page_no) {
  CURRENT_PAGE = page_no;
  $("#pdf-next, #pdf-prev").attr('disabled', 'disabled')
  $("#pdf-current-page").text(page_no)
  $("#pdf-current-page1").text(page_no)

  let page = await PDFDOC.getPage(page_no)

  let scale_required = Math.round(( 0.15 * (navigator.hardwareConcurrency<=4?((TOTAL_PAGES<=5)?(11-TOTAL_PAGES):6):navigator.hardwareConcurrency) + 0.2 ) * 100) / 100
  if(navigator.platform != "Win32")
    scale_required = Math.round(( 0.033 * (navigator.hardwareConcurrency<2?2:navigator.hardwareConcurrency) + 0.533 ) * 100) / 100

  // console.log(scale_required)

  let viewport = page.getViewport({scale: (scale_required || 2)})

  // console.log(viewport)

  CANVAS.height = viewport.height
  CANVAS.width = viewport.width

  // Render PDF page into canvas context
  let renderContext = {
    canvasContext: CANVAS_CTX,
    viewport: viewport
  }
  await page.render(renderContext).promise
  // console.log(CANVAS.toDataURL())
  docImage.src = CANVAS.toDataURL()
  docImage1.src = CANVAS.toDataURL()
  $("#pdf-next, #pdf-prev").removeAttr('disabled')
}

async function showPDF(pdf_url) {
  // The workerSrc property shall be specified.
  pdfjsLib.GlobalWorkerOptions.workerSrc = '/pdf/pdf.worker.min.js'

  // Asynchronous download of PDF
  let loadingTask = pdfjsLib.getDocument({url: pdf_url})
  loadingTask = loadingTask.promise
  PDFDOC = await loadingTask
  TOTAL_PAGES = PDFDOC.numPages

  $("#pdf-total-pages").text(TOTAL_PAGES);
  $("#pdf-total-pages1").text(TOTAL_PAGES);
  showPage(1)
}

function getMimetype(num, cb) {
  let filereader = new FileReader()
  filereader.readAsArrayBuffer(num)
  filereader.onloadend = function(evt) {
    if (evt.target.readyState === FileReader.DONE) {
      let uint = new Uint8Array(evt.target.result)
      let bytes = []
      uint.forEach((byte) => {
        bytes.push(byte.toString(16))
      })
      let hex = bytes.join('').toUpperCase()
      switch (hex) {
        case '89504E47':  //'image/png'
        case '47494638':  //'image/gif'
        case 'FFD8FFDB':
        case 'FFD8FFE1':
        case 'FFD8FFE0':
          return cb('image')
        case '25504446':
          return cb('application/pdf')
        default:
          return cb('Unknown filetype')
      }
    }
  }
}

function g64(pg) {
  return new Promise(async (resolve) => {
    let page = await PDFDOC.getPage(pg)
  
    let scale_required = 0.125 * (navigator.hardwareConcurrency<=4?((TOTAL_PAGES<=5)?(11-TOTAL_PAGES):6):navigator.hardwareConcurrency) + 0.5
  
    let vp = page.getViewport({scale: (scale_required || 2)})
  
    let nx = document.createElement("CANVAS")
    let nctx = nx.getContext('2d')
    nctx.imageSmoothingEnabled = 0
  
    nx.height = vp.height
    nx.width = vp.width

    let rContext = {
      canvasContext: nctx,
      viewport: vp
    }

    await page.render(rContext).promise
    resolve(nx.toDataURL())
  })
}

$(window).on('load', function() {
  $(".carousel-control-prev-icon").on('click', function() {
    if(CURRENT_PAGE != 1)
      showPage(--CURRENT_PAGE);
  })

  $(".carousel-control-next-icon").on('click', function() {
    if(CURRENT_PAGE != TOTAL_PAGES)
        showPage(++CURRENT_PAGE);
  })

  let x = document.createElement("CANVAS");
  let ctx = x.getContext('2d');
  ctx.imageSmoothingEnabled = 0
  
  let img = new Image();
  img.onload = function() {
    x.width = this.naturalWidth
    x.height = this.naturalHeight
    ctx.drawImage(img, 0, 0, this.naturalWidth, this.naturalHeight)
    imgData[0] = x.toDataURL()
  }
  
  let xhr = new XMLHttpRequest();
  let count = 1;
  let url = (window.location.href.indexOf('/docs/')!=-1?window.location.href.slice(0, window.location.href.indexOf('/docs/')):window.location.href.slice(0, window.location.href.indexOf('/link/'))) + "/file?id="+document.getElementById("fileid").innerText+"&user="+document.getElementById("aissuer").innerText
  console.log(url)
  xhr.open('GET', url , true);
  xhr.responseType = 'blob';
  
  xhr.onload = function(e) {
    if (this.status == 200) {
      let blob = this.response;
      let mNum = blob.slice(0, 4);
      getMimetype(mNum, async function(type) {
        // console.log("TYPE: ", type)
        if(type=="image") {
          let ccontrol = document.querySelectorAll(".carousel-main-control")
          img.src = URL.createObjectURL(blob)
          document.querySelector("#docimage").src = URL.createObjectURL(blob)
          document.querySelector("#docimage1").src = URL.createObjectURL(blob)
          TOTAL_PAGES = 1
          ccontrol[0].style.display = 'none'
          ccontrol[1].style.display = 'none'
          ccontrol[2].style.display = 'none'
          ccontrol[3].style.display = 'none'
        }
        if(type=="application/pdf") {
          actualfile = URL.createObjectURL(blob)
          console.log(actualfile)
          showPDF(URL.createObjectURL(blob))
          // let st = (new Date()).getTime()
          while(TOTAL_PAGES==undefined)
            await delay(500)
          for(let i = 1; i <= TOTAL_PAGES; i++ ) {
            imgData.push(await g64(i))
          }
          // let et = (new Date()).getTime()
          // console.log(et-st)
        }
      })
    }
  };
  
  xhr.send();
})

