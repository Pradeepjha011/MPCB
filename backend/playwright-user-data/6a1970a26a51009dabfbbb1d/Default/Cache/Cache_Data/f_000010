function time_remain() {
  let rtime = Math.floor(new Date().getTime()/1000)%86400
  if(rtime < 70200)
    num = 70200-rtime
  else
    num = 70200+86400-rtime
  // console.log(num)
  let hours = Math.floor(num/3600);
  let minutes = Math.floor((num%3600)/60);
  return hours + " hr :" + minutes + " min";
}

