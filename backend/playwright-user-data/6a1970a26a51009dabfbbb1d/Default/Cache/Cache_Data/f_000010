async function normalDownload() {
  $("[data-toggle='dpopover']").popover("hide")
  // console.log("btn clicked")
  if(cflag && TOTAL_PAGES >= 30) {
    document.getElementById('lowMsg').innerText = "This document appears to have more than 30 pages, Downloading in PDF will take a few more minutes than normal,you may use a better configuration system for better and faster results or do you want to proceed here?"
    $("#confirmLowModal").modal()
    return null
  }
  if(document.getElementById('dwl-link').href == "" && navigator.hardwareConcurrency <= 4 && navigator.platform == "Win32" && cflag && TOTAL_PAGES >= 6) {
    document.getElementById('lowMsg').innerText = "Your device is detected to have low cpu performance, downloading in PDF will take a few more minutes than normal, you may use a better configuration system for higher quality PDF or do you want to proceed here?"
    $("#confirmLowModal").modal()
    return null
  }
  if(document.querySelector('.alert.alert-danger.text-center.expired-alert') != null && eflag) {
    $("#expiredModal").modal()
    return null
  }
  if(document.querySelector('.alert.alert-danger.text-center.revoked-alert') != null && rflag) {
    $("#revokedModal").modal()
    return null
  }
  let btns = document.querySelectorAll('.btn.download-btn')
  btns[0].innerHTML = 'Preparing&nbsp&nbsp<i class="fa fa-cog fa-spin fa-fw"></i>'
  btns[1].innerHTML = 'Preparing&nbsp&nbsp<i class="fa fa-cog fa-spin fa-fw"></i>'
  // console.log(document.getElementById('pdflib'))
  console.log(TOTAL_PAGES)
  if(document.getElementById('pdflib')==null) {
    btns[0].disabled = true
    btns[1].disabled = true
    let jsElm = document.createElement("script")
    jsElm.id = 'pdflib'
    jsElm.type = "application/javascript";
    jsElm.src = '/js/bundle.min.js';
    document.body.appendChild(jsElm)
    jsElm.onload = async function() {
      console.log("PDF Lib downloaded")
      while(imgData.length!=TOTAL_PAGES) {
        console.log(imgData.length)
        await delay(1000)
      }
      document.getElementById('generatePDF').click()
    }
  } else {
    document.getElementById('dwl-link').click()
    btns[0].innerHTML = 'Download Again'
    btns[1].innerHTML = 'Download Again'
  }
  let xhr_download = new XMLHttpRequest();
  xhr_download.open("GET", "https://analytics."+domain+"/download?issuer="+document.getElementById("aissuer").innerText+"&doc="+document.getElementById('docid').innerText, true);
  xhr_download.send();
  
}

