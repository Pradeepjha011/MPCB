<script type="text/javascript">
    $(document).ready(function () {
        var url = "https://www.ecmpcb.in/";

        var selectedAuthority = "";
        var selectedOffice = "";

        if (selectedAuthority) {
            $('#granting_authority').val(selectedAuthority);
        }

        function loadGrantingOffices(authority, selectedOffice) {
            var grantingOffice = $('#granting_office');
            var authorityId = $('#granting_authority option:selected').attr("id"); // Get the selected option's ID

            grantingOffice.html('<option value="">Loading...</option>');

            if (authority === "") {
                grantingOffice.html('<option value="">All</option>');
                return;
            }

            if (authority !== "RO" && authority !== "SRO") {
                grantingOffice.html('<option id="' + authorityId + '" value="' + authority + '-HQ">' + authority + '-HQ</option>');

                if (selectedOffice === authority + "-HQ") {
                    grantingOffice.val(selectedOffice);
                }
            } else {
                $.ajax({
                    url: url + 'cms/get_offices_by_authority/',
                    type: 'POST',
                    data: {
                        granting_authority: authority,
                        "ci_csrf_token": ""
                    },
                    dataType: "json",
                    success: function (response) {
                        grantingOffice.html('<option value="' + authority + '">All</option>');

                        if (response.length > 0) {
                            $.each(response, function (index, office) {
                                grantingOffice.append('<option id="' + office.id + '" value="' + office.designation + '-' + office.office + '">' + office.designation + '-' + office.office + '</option>');
                            });

                            if (selectedOffice) {
                                grantingOffice.val(selectedOffice);
                            }
                        }
                    },
                    error: function () {
                        grantingOffice.html('<option value="">Error loading offices</option>');
                    }
                });
            }
        }

        if (selectedAuthority) {
            loadGrantingOffices(selectedAuthority, selectedOffice);
        }

        $('#granting_authority').on('change', function () {
            var authority = $(this).val();
            loadGrantingOffices(authority, '');
        });
    });
</script>


<script type="text/javascript">
    var url = "https://www.ecmpcb.in/";
    $(document).ready(function() {

        $('#mobile').on('change keypress', function(e) {

            var $this = $(this);
            var regex = new RegExp("^[0-9\b]+$");
            var str = String.fromCharCode(!e.charCode ? e.which : e.charCode);
            var error = $('.error-block');
            $('#tr_otp_number').hide();
            $('#btn_verify_otp').hide();
            error.html('');

            if ($this.val().length > 10) {
                e.preventDefault();
                error.html('Accept Only 10 Digit Number');
                return false;
            }

            if (e.charCode < 54 && e.charCode > 47) {
                if ($this.val().length == 0) {
                    e.preventDefault();
                    error.html('Accept Only 10 Digit Number');
                    return false;
                } else {
                    return true;
                }
            }

            if (regex.test(str)) {
                return true;
            }
            e.preventDefault();
            return false;
        });

        $("#btn_send_otp").on('click', function(e) {
            var mobileNumber = $('#mobile').val();
            var error = $('.error-block');
            error.html('');

            if (mobileNumber.length != 10) {
                e.preventDefault();
                error.html('Accept Only 10 Digit Number');
                return false;
            }

            $.ajax({
                url: url + 'cms/send_otp_download_file/',
                type: 'POST',
                data: {
                    mobile: mobileNumber,
                    "ci_csrf_token": ""
                },
                dataType: 'json',
                success: function(data) {
                    if (data.response) {
                        $('#span_download_link').hide();
                        $('#tr_otp_number').show();
                        $('#btn_verify_otp').show();
                    } else {
                        error.html(data.message);
                    }
                }
            });
        });

        $("#btn_verify_otp").on('click', function(e) {
            var submitData = $('#hid_submit_data').val();
            var otpNumber = $('#otp_number').val();
            var error = $('.error-block');
            error.html('');

            $.ajax({
                url: url + 'cms/verif_download_otp/',
                type: 'POST',
                data: {
                    otp_number: otpNumber,
                    submit_data: submitData,
                    "ci_csrf_token": ""
                },
                dataType: 'json',
                success: function(data) {
                    if (data.response) {
                        $('#tr_otp_number').hide();
                        $('#btn_verify_otp').hide();
                        $('#span_download_link').show();
                        $("#anc_download_link").attr("href", data.download_link);
                    } else {
                        $('#error_response').html(data.message);
                    }
                }
            });
        });

        $('#send_otp_modal').on('hidden.bs.modal', function() {
            $('.error-block').html('');
            $('#span_download_link').hide();
        });
    });

    $(document).on('click', '#btn_download_link', function() {
        var unique_id = $(this).data('unique-id');
        var download_link = $(this).data('link');
        var industry_name = $(this).data('name');
        var submit_data = unique_id + '|' + industry_name + '|' + download_link;

        $('#hid_submit_data').val(submit_data);
        $('#send_otp_modal').modal('show');
    });
</script>
