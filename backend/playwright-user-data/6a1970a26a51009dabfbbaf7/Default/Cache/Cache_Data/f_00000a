$('.add-more').click(function(){
    var btn = $(this).closest('li');
    var html = btn.prev().html();
    var index = parseInt(html.match(/\[[0-9]+\]/g)[0].match(/\d+/)) + 1;   // Get the previous index
    var srNo = index + 1;
    html = html.replace(/S[0-9]/,'S' + srNo);
    html = html.replace(/<label>[0-9]<\/label>/,'<label>' + srNo + '</label>' );
    btn.before('<li>'+html.replace(/\[[0-9]+\]/g,'['+ index +']')+'</li>');
    btn.prev().find('select, input').first().focus();
    product_add_more_select2();
    return false;
});

