$('.greater_zero').change(function(){
    if($(this).val() < 1) {
        var message = $(this).data('nonzero');

        if (!message &&  message==null) {
            message = "Field value must be greater than zero.";
        }

        swal("Error", message, "error")
        $(this).val('');
    }
});







